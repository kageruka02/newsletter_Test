<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd">

<suite name="NewsletterTestSuite" verbose="1">

    <!--
        All tests in one <test> block so @BeforeMethod and @AfterMethod
        run correctly before and after every test method.
        Groups (smoke / regression) are still respected when filtering.
    -->
    <test name="Newsletter Tests">
        <classes>
            <class name="com.automation.tests.NewsletterTest"/>
        </classes>
    </test>

</suite>